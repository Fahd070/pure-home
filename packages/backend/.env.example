# ─────────────────────────────────────────────────────────────────────────────
# WFM System — Backend Environment Variables
# Copy this file to .env for local development.
# On Render, set these in the service's Environment tab — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Use Supabase's TRANSACTION POOLER URL (port 6543) for Render compatibility.
# Project Settings → Database → Connection String → Transaction mode
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Must be at least 32 characters. Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ── Department Access Codes (OPTIONAL — DB takes precedence) ──────────────────
# These are only used when:
#   (a) The system_configs table does not yet contain a record for this dept, AND
#   (b) The database is unreachable (fallback of last resort)
# Change codes through the Admin → Access Codes page, not here.
ADMIN_CODE=9012
SCHEDULING_CODE=9013
TECHNICIAN_CODE=9014

# ── Technician Account Binding (OPTIONAL) ─────────────────────────────────────
# Email of the user account selected when a technician logs in via access code.
TECHNICIAN_EMAIL=tech1@wfm.local

# ── Server Binding (OPTIONAL — Render sets PORT automatically) ────────────────
PORT=3001
BIND_HOST=0.0.0.0

# ── Set automatically by Render — DO NOT set manually ─────────────────────────
# RENDER=true
# RENDER_EXTERNAL_URL=https://wfm-system.onrender.com
