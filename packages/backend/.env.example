# Database — update credentials to match your PostgreSQL setup
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/wfm_db"

# JWT — generate a strong secret: node -e "require('crypto').randomBytes(48).toString('hex').then(console.log)"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# Server port
PORT=3001
NODE_ENV=development

# Department access codes — change these from defaults
ADMIN_CODE=9012
SCHEDULING_CODE=9013
TECHNICIAN_CODE=9014

# Email of the default technician account used by code-login
TECHNICIAN_EMAIL=tech1@wfm.local

# Seed passwords — set these before running: npm run db:seed
# Choose strong passwords and store them securely after seeding
SEED_ADMIN_PASSWORD=REPLACE_BEFORE_SEEDING
SEED_SCHEDULING_PASSWORD=REPLACE_BEFORE_SEEDING
SEED_TECHNICIAN_PASSWORD=REPLACE_BEFORE_SEEDING
